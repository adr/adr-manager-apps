# Mirror npm's flat node_modules so the legacy Vue2/Vuetify2 toolchain and `vsce`
# packaging resolve the same way they did in the original standalone repos.
node-linker=hoisted

# Tolerate the older peer graphs (Vue 2.7, @vuelidate alphas, vue-class-component 8.0.0-0)
# rather than failing install.
strict-peer-dependencies=false
