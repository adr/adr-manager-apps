{
    "name": "adr-manager",
    "version": "2.0.0",
    "type": "module",
    "private": true,
    "engines": {
        "node": ">=22.13"
    },
    "prettier": "@adr-manager/prettier-config",
    "scripts": {
        "start": "vite",
        "dev": "vite",
        "build": "vue-tsc --noEmit && vite build",
        "typecheck": "vue-tsc --noEmit",
        "serve": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "e2e:test": "cypress run",
        "e2e:test-ci": "cypress run --browser chrome --headless --config video=false,screenshotOnRunFailure=false",
        "format": "prettier --write . --ignore-unknown",
        "lint": "eslint ."
    },
    "dependencies": {
        "@adr-manager/core": "workspace:*",
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/language": "^6.12.3",
        "@codemirror/merge": "^6.12.1",
        "@codemirror/state": "^6.6.0",
        "@codemirror/view": "^6.43.0",
        "@lezer/highlight": "^1.2.3",
        "@mdi/font": "^7.4.47",
        "antlr4": "catalog:",
        "axios": "^1.17.0",
        "codemirror": "^6.0.2",
        "firebase": "^12.14.0",
        "marked": "^18.0.5",
        "roboto-fontface": "^0.10.0",
        "sanitize-filename": "^1.6.4",
        "sweetalert2": "^11.26.25",
        "vue": "catalog:",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@adr-manager/eslint-config": "workspace:*",
        "@adr-manager/prettier-config": "workspace:*",
        "@adr-manager/tsconfig": "workspace:*",
        "@cypress/code-coverage": "^4.0.3",
        "@types/node": "catalog:",
        "@vitejs/plugin-vue": "catalog:",
        "@vitest/coverage-v8": "^4.1.8",
        "@vue/test-utils": "^2.4.11",
        "cypress": "^15.16.0",
        "cypress-vite": "^1.10.0",
        "eslint": "catalog:",
        "jsdom": "^29.1.1",
        "prettier": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:",
        "vue-tsc": "catalog:"
    }
}
