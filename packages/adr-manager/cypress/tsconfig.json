{
    "compilerOptions": {
        "target": "ES2021",
        "lib": ["ES2021", "DOM"],
        "types": ["cypress", "node"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "isolatedModules": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": ["**/*.ts", "../cypress.config.ts"]
}
