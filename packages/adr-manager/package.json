{
    "name": "adr-manager",
    "version": "2.0.0",
    "type": "module",
    "private": true,
    "engines": {
        "node": ">=22.13"
    },
    "prettier": "@adr-manager/prettier-config",
    "scripts": {
        "start": "vite",
        "dev": "vite",
        "build": "vue-tsc --noEmit && vite build",
        "typecheck": "vue-tsc --noEmit",
        "serve": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "e2e:test": "cypress run",
        "e2e:test-ci": "cypress run --browser chrome --headless --config video=false,screenshotOnRunFailure=false",
        "format": "prettier --write . --ignore-unknown",
        "lint": "eslint ."
    },
    "dependencies": {
        "@adr-manager/core": "workspace:*",
        "@codemirror/commands": "^6.0.0",
        "@codemirror/lang-markdown": "^6.0.0",
        "@codemirror/language": "^6.0.0",
        "@codemirror/merge": "^6.0.0",
        "@codemirror/state": "^6.0.0",
        "@codemirror/view": "^6.0.0",
        "@mdi/font": "^7.2.96",
        "antlr4": "catalog:",
        "axios": "^1.4.0",
        "codemirror": "^6.0.0",
        "firebase": "^10.7.0",
        "marked": "^12.0.0",
        "roboto-fontface": "*",
        "sanitize-filename": "^1.6.3",
        "splitpanes": "^4.0.0",
        "sweetalert2": "^11.0.0",
        "vue": "catalog:",
        "vue-easy-dnd": "^2.0.0",
        "vue-router": "^4.4.0",
        "vue-tippy": "^6.0.0",
        "vuetify": "^4.1.0"
    },
    "devDependencies": {
        "@adr-manager/eslint-config": "workspace:*",
        "@adr-manager/prettier-config": "workspace:*",
        "@adr-manager/tsconfig": "workspace:*",
        "@cypress/code-coverage": "^3.11.0",
        "@types/node": "catalog:",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vitest/coverage-v8": "^3.0.0",
        "@vue/test-utils": "^2.4.0",
        "cypress": "^12.17.1",
        "cypress-vite": "^1.4.1",
        "eslint": "catalog:",
        "jsdom": "^25.0.0",
        "prettier": "catalog:",
        "sass": "catalog:",
        "typescript": "catalog:",
        "vite": "^6.0.0",
        "vite-plugin-vuetify": "^2.1.0",
        "vitest": "catalog:",
        "vue-tsc": "^2.1.0"
    }
}
