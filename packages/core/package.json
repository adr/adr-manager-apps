{
  "name": "@adr-manager/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared MADR parser, ADR domain model, and utilities for the ADR Manager monorepo",
  "engines": {
    "node": ">=22.13"
  },
