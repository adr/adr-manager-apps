{
  "$schema": "https://json.schemastore.org/tsconfig",
  // For the VS Code extension host (CommonJS, Node, emits to dist; allowJs for generated ANTLR sources).
  "extends": "./base.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ESNext",
    // TS 6 deprecates "node" (node10) resolution; "bundler" matches the esbuild-bundled host.
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "sourceMap": true,
    "allowJs": true
  }
}
