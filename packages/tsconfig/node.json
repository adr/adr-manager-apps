{
  "$schema": "https://json.schemastore.org/tsconfig",
  // For Node tooling config files (vite.config, vitest.config, cypress.config).
  "extends": "./base.json",
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "noEmit": true
  }
}
