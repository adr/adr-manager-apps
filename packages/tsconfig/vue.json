{
  "$schema": "https://json.schemastore.org/tsconfig",
  // For Vue / bundler-compiled apps (Vite web app, extension web views). Type-check only; the bundler emits.
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "noEmit": true
  }
}
